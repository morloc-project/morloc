-- Variable-width element types (e.g. Str) exercise the buffer's
-- index + data section layout: each element's inline part lives
-- in the index section (16 B per Str = {size, relptr}); each
-- element's variable bytes live in the data section. The flush
-- path compacts the wasted index space and shifts inline relptrs
-- to point at their data in the compacted output.
--
-- Two @writes with strings of different lengths exercise that
-- the runtime correctly:
--   * appends inline {size, relptr} pairs to the index
--   * copies variable str bytes into the data section
--   * shifts each str's relptr at flush time to be packet-relative
--
-- All five strings must round-trip identically.

module main
  ( testStringsRoundtrip
  , testStringsCount
  )

import root

writeStrings :: Str -> <IO, Err> ()
writeStrings path = do
  o <- @open path :: <IO, Err> OStream Str
  @write 0 o ["apple", "banana", "cherry"]
  @write 0 o ["date", "elderberry"]
  @close o

-- Coalesces into one sub-packet via the buffer; reader sees
-- all five strings in order.
testStringsRoundtrip :: Str -> <IO, Err> [Str]
testStringsRoundtrip path = do
  writeStrings path
  s <- @open path :: <IO, Err> IStream Str
  @next s

testStringsCount :: Str -> <IO, Err> Int
testStringsCount path = do
  writeStrings path
  s <- @open path :: <IO, Err> IStream Str
  @flen s
