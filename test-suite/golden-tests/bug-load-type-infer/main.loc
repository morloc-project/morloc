-- Regression: @load's fresh-variable return type must be propagated
-- from the enclosing function's declared return type through the
-- do-block handler.  Post effect-migration, @load returns `<IO, Err> a`
-- and the same inference constraint applies to `a`.
module main (roundTrip)

import root-py

source Py from "helper.py" ("identity")
identity :: a -> a

roundTrip :: Int -> Str -> <IO, Err> Int
roundTrip x path = do
  @save 0 (identity x) path
  x <- @load path
  x
