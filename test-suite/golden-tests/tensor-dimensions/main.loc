-- Test all tensor dimensions (1D through 5D) with Python->C++ cross-language.
module main
  ( t1d
  , t2d
  , t3d
  , t4d
  , t5d
  , testSum1d
  , testSum2d
  , testSum3d
  , testSum4d
  , testSum5d
  )

import root
import root-py
import root-cpp
import tensor
import tensor-cpp
import tensor-py

source Py from "src.py"
  ( "make1d" as pyMake1d
  , "make2d" as pyMake2d
  , "make3d" as pyMake3d
  , "make4d" as pyMake4d
  , "make5d" as pyMake5d
  )

source Cpp from "src.hpp"
  ( "cppSum1d"
  , "cppSum2d"
  , "cppSum3d"
  , "cppSum4d"
  , "cppSum5d"
  )

pyMake1d :: Vector 6 Int32
pyMake2d :: Matrix 2 3 Int32
pyMake3d :: Tensor3 2 3 4 Int32
pyMake4d :: Tensor4 2 3 2 2 Int32
pyMake5d :: Tensor5 2 2 2 3 2 Int32

cppSum1d :: Vector 6 Int32 -> Int32
cppSum2d :: Matrix 2 3 Int32 -> Int32
cppSum3d :: Tensor3 2 3 4 Int32 -> Int32
cppSum4d :: Tensor4 2 3 2 2 Int32 -> Int32
cppSum5d :: Tensor5 2 2 2 3 2 Int32 -> Int32

t1d = pyMake1d
t2d = pyMake2d
t3d = pyMake3d
t4d = pyMake4d
t5d = pyMake5d

testSum1d :: Int32
testSum1d = cppSum1d pyMake1d

testSum2d :: Int32
testSum2d = cppSum2d pyMake2d

testSum3d :: Int32
testSum3d = cppSum3d pyMake3d

testSum4d :: Int32
testSum4d = cppSum4d pyMake4d

testSum5d :: Int32
testSum5d = cppSum5d pyMake5d
