intListId x = x

uint16Id :: UInt16 -> UInt16
uint16Id x = x

uint32Id :: UInt32 -> UInt32
uint32Id x = x

uint64Id :: UInt64 -> UInt64
uint64Id x = x

int8Id :: Int8 -> Int8
int8Id x = x

int16Id :: Int16 -> Int16
int16Id x = x

int32Id :: Int32 -> Int32
int32Id x = x

int64Id :: Int64 -> Int64
int64Id x = x



pintDbl :: Int -> Int
pintDbl x = idpy (x * 2)

puint8Dbl :: UInt8 -> UInt8
puint8Dbl x = idpy (x * 2)

puint16Dbl :: UInt16 -> UInt16
puint16Dbl x = idpy (x * 2)

puint32Dbl :: UInt32 -> UInt32
puint32Dbl x = idpy (x * 2)

puint64Dbl :: UInt64 -> UInt64
puint64Dbl x = idpy (x * 2)

pint8Dbl :: Int8 -> Int8
pint8Dbl x = idpy (x * 2)

pint16Dbl :: Int16 -> Int16
pint16Dbl x = idpy (x * 2)

pint32Dbl :: Int32 -> Int32
pint32Dbl x = idpy (x * 2)

pint64Dbl :: Int64 -> Int64
pint64Dbl x = idpy (x * 2)



