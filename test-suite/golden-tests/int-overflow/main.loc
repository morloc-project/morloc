cintDbl x = idcpp (x * 2)

cuint8Dbl :: UInt8 -> UInt8
cuint8Dbl x = idcpp (x * 2)

cuint16Dbl :: UInt16 -> UInt16
cuint16Dbl x = idcpp (x * 2)

cuint32Dbl :: UInt32 -> UInt32
cuint32Dbl x = idcpp (x * 2)

