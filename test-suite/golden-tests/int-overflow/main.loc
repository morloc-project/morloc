rintDbl :: Int -> Int
rintDbl x = idr (x * 2)

ruint8Dbl :: UInt8 -> UInt8
ruint8Dbl x = idr (x * 2)

ruint16Dbl :: UInt16 -> UInt16
ruint16Dbl x = idr (x * 2)

ruint32Dbl :: UInt32 -> UInt32
ruint32Dbl x = idr (x * 2)

ruint64Dbl :: UInt64 -> UInt64
ruint64Dbl x = idr (x * 2)

rint8Dbl :: Int8 -> Int8
rint8Dbl x = idr (x * 2)

rint16Dbl :: Int16 -> Int16
rint16Dbl x = idr (x * 2)

rint32Dbl :: Int32 -> Int32
rint32Dbl x = idr (x * 2)

rint64Dbl :: Int64 -> Int64
rint64Dbl x = idr (x * 2)



-- R identity round-trips. R has only "integer" (32-bit signed) and
-- "numeric" (double, exact integers up to 2^53). Int64 / UInt32 / UInt64
-- map to "numeric"; values beyond 2^53 are not exactly representable and
-- may silently lose precision.
rintId :: Int -> Int
rintId x = idr x

rint8Id :: Int8 -> Int8
rint8Id x = idr x

rint16Id :: Int16 -> Int16
rint16Id x = idr x

rint32Id :: Int32 -> Int32
rint32Id x = idr x

rint64Id :: Int64 -> Int64
rint64Id x = idr x

ruint8Id :: UInt8 -> UInt8
ruint8Id x = idr x

ruint16Id :: UInt16 -> UInt16
ruint16Id x = idr x

ruint32Id :: UInt32 -> UInt32
ruint32Id x = idr x

ruint64Id :: UInt64 -> UInt64
ruint64Id x = idr x

-- R source returns NA_integer_; the wire-pack into Int8 must refuse
-- rather than silently casting NaN to INT8_MIN.
returnNAInt8 :: Int8 -> Int8
source R from "naSrc.R" ("returnNAInt8" as returnNAInt8)
