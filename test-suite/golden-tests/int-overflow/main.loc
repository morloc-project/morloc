cuint64Dbl x = idcpp (x * 2)

cint8Dbl :: Int8 -> Int8
cint8Dbl x = idcpp (x * 2)

cint16Dbl :: Int16 -> Int16
cint16Dbl x = idcpp (x * 2)

cint32Dbl :: Int32 -> Int32
cint32Dbl x = idcpp (x * 2)

cint64Dbl :: Int64 -> Int64
