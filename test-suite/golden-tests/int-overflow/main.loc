module main (
  -- pure morloc
  bigVarInt,
  uint8ListId,
  intListId,
  intId,
  int16Id,
  int32Id,
  int64Id,
  int8Id,
  intId,
  uint8Id,
  uint16Id,
  uint32Id,
  uint64Id,
  -- python
  pintDbl,
  pint16Dbl,
  pint32Dbl,
  pint64Dbl,
  pint8Dbl,
  pintDbl,
  puint16Dbl,
  puint32Dbl,
  puint64Dbl,
  puint8Dbl,
  -- r
  rintDbl,
  rint16Dbl,
  rint32Dbl,
  rint64Dbl,
  rint8Dbl,
  rintDbl,
  ruint16Dbl,
  ruint32Dbl,
  ruint64Dbl,
  ruint8Dbl,
  -- r identity (round-trip through R; exposes 2^53 numeric limit)
  rintId,
  rint8Id,
  rint16Id,
  rint32Id,
  rint64Id,
  ruint8Id,
  ruint16Id,
  ruint32Id,
  ruint64Id,
  -- r NA: source returns NA_integer_; pack-side must refuse
  returnNAInt8,
  -- cpp
  cintDbl,
  cint16Dbl,
  cint32Dbl,
  cint64Dbl,
  cint8Dbl,
  cintDbl,
  cuint16Dbl,
  cuint32Dbl,
  cuint64Dbl,
  cuint8Dbl
)

import root-py
import root-cpp
import root-r

bigVarInt :: Int
bigVarInt = 123456789012345678901234567890

intId :: Int -> Int
intId x = x

uint8Id :: UInt8 -> UInt8
uint8Id x = x

uint8ListId :: [UInt8] -> [UInt8]
uint8ListId x = x

