module main
  ( testNull
  , testValue
  , testFromNull
  , testSafeHead
  , testSafeHeadEmpty
  , testOptionalAdd
  , testOptionalAddNull
  , testOptionalList
  , testCountNulls
  , testNestedNull
  , testNestedValue
  , testNestedRoundTrip
  , testNestedRoundTripNull
  , testNestedJustNull
  )

type Cpp => Int = "int"
type Cpp => Bool = "bool"
type Cpp => Str = "std::string"
type Cpp => List a = "std::vector<$1>" a

isNull :: ?a -> Bool
fromNull :: a -> ?a -> a
toNull :: a -> ?a
safeHead :: [Int] -> ?Int
optionalAdd :: ?Int -> ?Int -> ?Int
optionalList :: [Int] -> [?Int]
countNulls :: [?Int] -> Int
identityNested :: ?(?Int) -> ?(?Int)
mkJustNull :: Int -> ?(?Int)

source Cpp from "foo.hpp"
  ( "isNull"
  , "fromNull"
  , "toNull"
  , "safeHead"
  , "optionalAdd"
  , "optionalList"
  , "countNulls"
  , "identityNested"
  , "mkJustNull"
  )

testNull :: ?Int
testNull = Null

testValue :: ?Int
testValue = toNull 42

testFromNull :: Int
testFromNull = fromNull 0 Null

testSafeHead :: ?Int
testSafeHead = safeHead [10, 20, 30]

testSafeHeadEmpty :: ?Int
testSafeHeadEmpty = safeHead []

testOptionalAdd :: ?Int
testOptionalAdd = optionalAdd (toNull 3) (toNull 4)

testOptionalAddNull :: ?Int
testOptionalAddNull = optionalAdd Null (toNull 4)

testOptionalList :: [?Int]
testOptionalList = optionalList [1, -2, 3, -4, 5]

testCountNulls :: Int
testCountNulls = countNulls (optionalList [1, -2, 3, -4, 5])

-- Nested optional: pure-nexus literal coerced from Int through ?Int to ?(?Int)
testNestedNull :: ?(?Int)
testNestedNull = Null

testNestedValue :: ?(?Int)
testNestedValue = 42

-- Nested optional: round-trip through a C++ pool function. Exercises
-- cross-language serialization of the nested-optional voidstar layout.
testNestedRoundTrip :: ?(?Int)
testNestedRoundTrip = identityNested 42

testNestedRoundTripNull :: ?(?Int)
testNestedRoundTripNull = identityNested Null

-- Outer Just, inner Null: a state std::optional<std::optional<T>> can
-- represent distinctly from outer Null. Serializes to JSON `null` because
-- JSON has only one null sentinel, but exercises the layered tag bytes.
testNestedJustNull :: ?(?Int)
testNestedJustNull = mkJustNull 0
