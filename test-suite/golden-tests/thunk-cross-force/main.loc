-- Test cross-language nullary effect evaluation as function arguments.

module main (combined, addForced)

import root-cpp
import root-py

source Py from "foo.py" ("get_name", "get_value")
source Cpp from "foo.hpp" ("combine", "add")

type Cpp => Int = "int"
type Py => Int = "int"
type Cpp => Str = "std::string"
type Py => Str = "str"

get_name :: <IO> Str
get_value :: <IO> Int
combine :: Str -> Int -> Str
add :: Int -> Int -> Int

combined :: <IO> Str
combined = do
    n <- get_name
    v <- get_value
    combine n v

addForced :: <IO> Int
addForced = do
    x <- get_value
    y <- get_value
    add x y
