module main
  ( map_size_tsv
  , map_size_json
  , map_values_sum
  , map_keys_joined
  )

import root-py
import map-py

source Py from "helper.py"
  ( "py_size_map"
  , "py_sum_values"
  , "py_keys_sorted_joined"
  )

py_size_map          :: Map Str Int -> Int
py_sum_values        :: Map Str Int -> Int
py_keys_sorted_joined :: Map Str Int -> Str

--' `Map Str Int` reads from a two-column TSV file via `form: list`
--' because its Packable wire form is `[(Str, Int)]`. The tabular
--' fallback engages on the list-of-tuple element shape after the
--' outer `<Map>` hint is peeled by the CLI schema classifier.
map_size_tsv ::
  --' form: list
  Map Str Int -> Int
map_size_tsv m = py_size_map m

--' Same schema, JSON-array-per-line variant. `["a",1]` per line.
map_size_json ::
  --' form: list
  Map Str Int -> Int
map_size_json m = py_size_map m

--' Sum the values after Map is loaded from a two-column table.
--' Confirms the keys and values landed at their intended positions
--' rather than being swapped.
map_values_sum ::
  --' form: list
  Map Str Int -> Int
map_values_sum m = py_sum_values m

--' Round-trip check: keys read from the table match what we expect.
--' Sorted+joined so output is order-independent.
map_keys_joined ::
  --' form: list
  Map Str Int -> Str
map_keys_joined m = py_keys_sorted_joined m
