module main (sliced, sorted, picked, reversed_)

import tables-py

source Py from "src.py" ("mkData")

-- Stage 6 stdlib operation tests. The driver function `mkData n` returns a
-- typed Table 5 {x=Int, y=Str} with x = 0..n-1 and y = "r0".."r(n-1)"; the
-- tests below each run a single new operation end-to-end.

mkData :: Int -> Table n {x=Int, y=Str}

-- sliceRows: take rows [start, start+length) with non-negative clamping.
sliced :: Int -> Table m {x=Int, y=Str}
sliced n = sliceRows 1 2 (mkData n)

-- arrangeDesc: sort by named column descending. Ascending is `arrange`.
sorted :: Int -> Table n {x=Int, y=Str}
sorted n = arrangeDesc "x" (mkData n)

-- select: project a subset of columns. The output Rec is left polymorphic;
-- the function's return type fixes it.
picked :: Int -> Table n r2
picked n = select ["y"] (mkData n)

-- reverseRows: reverse the row order, preserving Nat and Rec.
reversed_ :: Int -> Table n {x=Int, y=Str}
reversed_ n = reverseRows (mkData n)
