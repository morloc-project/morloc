-- End-to-end golden for the gradual `Vector T` (no Nat annotation)
-- form on the Python side. Exercises:
--   * gradual `Vector U8` returned from a sourced Py function
--   * het-length `[Vector U8]` accepting elements of varying lengths
--   * concrete `Vector 3 U8` flowing into a `Vector U8` slot
--   * wire round-trip preserving the gradual form

module main
  ( sizeSingle
  , sizeMany
  , sizeConcrete
  , sizeAfterRoundTrip
  )

import root-py
import vector-py

source Py from "main.py" ("mk_vec" as mkVec)
mkVec :: Int -> Vector U8

source Py from "main.py" ("mk_three" as mkThree)
mkThree :: Vector 3 U8

sizeSingle :: Int -> U64
sizeSingle n = size (mkVec n)

sizeMany :: [Int] -> [U64]
sizeMany ns = map size (map mkVec ns)

sizeConcrete :: U64
sizeConcrete = takeGradual mkThree

takeGradual :: Vector U8 -> U64
takeGradual = size

sizeAfterRoundTrip :: U64
sizeAfterRoundTrip = size (mkVec 5)
