module main
  ( setSingleHet
  , setTwoHet
  , setLastHet
  , setReorderArgs
  , setMixedNested
  , setI32Lit
  , setU32Lit
  , setMixedWidthTwo
  )

-- Pure-morloc setter exports: each evaluates entirely in the nexus
-- (no language pool), exercising apply_setter_copy / apply_setter_set
-- in the Rust runtime. All record literals are heterogeneous so the
-- on-wire field offsets differ from a same-typed projection.

-- Single key on a heterogeneous record.
setSingleHet = .(.x = 99) { x = 0, y = "hi", z = 8 }

-- Two keys, both written on a heterogeneous record. Regression for
-- the foldr / foldl bug in selectorSetter where setTypes were matched
-- to selectors in reverse order, swapping the inferred field types.
setTwoHet = .(.x = 99, .y = "world") { x = 0, y = "hi", z = 8 }

-- Setter that writes the last field of a heterogeneous record.
setLastHet = .(.z = 50) { x = 0, y = "hi", z = 8 }

-- Two setters written in reverse-key order at the source. Catches a
-- bug where the runtime walk and the typecheck disagreed on whether
-- selector order or value-list order drives the field/value pairing.
setReorderArgs = .(.z = 99, .x = "first") { x = "old", y = 1.5, z = 0 }

-- Heterogeneous record containing a tuple field, with one setter on a
-- scalar key and another via a chained selector into the tuple.
setMixedNested = .(.x = 42, .y.0 = "rewritten") { x = 0, y = ("orig", 1), z = 3.14 }

-- Numeric-literal defaulting on a fixed-width integer field. The
-- setter value `42` is an integer literal; the target slot is I32
-- via the record signature. Should compile (Int literals inhabit any
-- integer-family type when checked against a concrete width) and set
-- .n to 42. Regression for the setter-path analogue of the IntrMap
-- literal-freezing bug: the setter synth clause synths set-values
-- BEFORE checking the receiver, so `42` freezes to Int and the
-- receiver check against `{n :: I32}` explodes with
-- "Cannot compare types I32 and Int".
setI32Lit :: Row32
setI32Lit = .(.n = 42) { n = 0, s = "hi" }

-- Same bug shape but on U32, ruling out any Int-specific fluke.
setU32Lit :: RowU32
setU32Lit = .(.n = 100) { n = 0, s = "hi" }

-- Two literals of the same shape, one for each integer-family field
-- with a different width. Exercises whether per-slot defaulting
-- propagates independently through the group setter.
setMixedWidthTwo :: MixedRow
setMixedWidthTwo = .(.a = 7, .b = 1000) { a = 0, b = 0, tag = "x" }

record Row32 where
  n :: I32
  s :: Str

record RowU32 where
  n :: U32
  s :: Str

record MixedRow where
  a :: I8
  b :: U32
  tag :: Str
