module main (combo)

import tables-py

source Py from "src.py" ("makeX", "makeY")

-- Stage 4 stdlib operation: cbind unions Rec schemas via the polymorphic `+`
-- and requires both inputs to share a row count n.
makeX :: Int -> Table n {x=Int}
makeY :: Int -> Table n {y=Str}

combo :: Int -> Table n ({x=Int} + {y=Str})
combo n = cbind (makeX n) (makeY n)
