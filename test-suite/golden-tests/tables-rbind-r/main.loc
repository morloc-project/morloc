module main (twiceR)

import tables-r

source R from "src.R" ("makeT_r")

-- Stage 4 stdlib operation in R: rbind composes row counts via Nat addition
-- and preserves the Rec schema. R impl uses data.frame round-trip for
-- columnar concatenation.
makeT_r :: Int -> Table n {x=Int, y=Str}

twiceR :: Int -> Table m {x=Int, y=Str}
twiceR n =
  let t = makeT_r n
  in rbind t t
