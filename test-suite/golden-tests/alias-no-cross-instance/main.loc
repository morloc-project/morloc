-- Negative test: sibling aliases must NOT inherit each other's instances.
--
-- Alias family:
--   Str (root) -- no Qux instance
--   +-- A      -- has Qux instance
--   |   +-- B
--   +-- A'     -- no Qux instance
--       +-- B'
--
-- Qux is defined ONLY for A (and B inherits it). There is NO Qux Str.
-- Attempting to use doqux at type A' should fail because:
--   1. No instance Qux A'
--   2. A' reduces to Str: no instance Qux Str
--   3. Sibling A's instance must NOT be used

module main (shouldFail)

import root-py

type A = Str
type B = A

type A' = Str
type B' = A'

class Qux a where
  doqux :: a -> Str

instance Qux A where
  doqux x = "#{x} : A"

-- No instance Qux Str
-- No instance Qux A'

shouldFail = doqux ("x" :: A')
