-- @flush between @writes produces distinct sub-packets.
-- Two @writes + @flush in between yields TWO sub-packets,
-- not one coalesced one. The reader's first @next sees the
-- first batch, the second @next sees the second batch.
--
-- This is the test that proves @flush actually flushes (rather
-- than being a no-op that gets coalesced anyway).

module main
  ( testFlushFirst
  , testFlushSecond
  , testFlushThird
  , testFlushEof
  )

import root

writeWithFlushes :: Str -> <IO, Err> ()
writeWithFlushes path = do
  o <- @open path :: <IO, Err> OStream Int
  @write 0 o [10, 20, 30]
  @flush o
  @write 0 o [40, 50]
  @flush o
  @write 0 o [60, 70, 80, 90]
  @close o

testFlushFirst :: Str -> <IO, Err> [Int]
testFlushFirst path = do
  writeWithFlushes path
  s <- @open path :: <IO, Err> IStream Int
  @next s

testFlushSecond :: Str -> <IO, Err> [Int]
testFlushSecond path = do
  writeWithFlushes path
  s <- @open path :: <IO, Err> IStream Int
  @next s
  @next s

testFlushThird :: Str -> <IO, Err> [Int]
testFlushThird path = do
  writeWithFlushes path
  s <- @open path :: <IO, Err> IStream Int
  @next s
  @next s
  @next s

testFlushEof :: Str -> <IO, Err> [Int]
testFlushEof path = do
  writeWithFlushes path
  s <- @open path :: <IO, Err> IStream Int
  @next s
  @next s
  @next s
  @next s
