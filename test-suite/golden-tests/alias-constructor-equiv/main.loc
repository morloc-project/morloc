-- Test that @List@ and @Deque@ (newtype-of-List with a @Packable
-- (List a) (Deque a)@ instance) support the same Monoid / Semigroup
-- / Foldable / Functor operations on values constructed via list
-- literals. Each comparison annotates both sides at the same nominal
-- type since newtypes are nominally distinct (no implicit
-- @Deque == List@ across the newtype boundary). The earlier @Array@
-- type has been removed in favor of @Vector@.

module main (testConcatPy, testConcatCpp, testConcatR)

import root-py
import root-cpp
import root-r

testConcatPy :: Bool
testConcatPy =
  let t1  = idpy $ (concat ([[1,2],[3],[4,5]] :: List (List Int))) == ([1,2,3,4,5] :: List Int)
      t2  = idpy $ (intercalate [0] [[1,2],[3,4],[5]]) == ([1,2,0,3,4,0,5] :: [Int])
      t3  = idpy $ (([1,2] :: [Int]) <> [3,4]) == ([1,2,3,4] :: [Int])
      t4  = idpy $ (([1,2] :: Deque Int) <> [3,4]) == ([1,2,3,4] :: Deque Int)
      t5  = idpy $ ((mempty :: [Int])) == ([] :: [Int])
      t6  = idpy $ ((mempty :: Deque Int)) == ([] :: Deque Int)
      t7  = idpy $ (fold (+) 0 ([1,2,3,4] :: Deque Int)) == 10
      t8  = idpy $ (map (\x -> x + 1) ([1,2,3] :: Deque Int)) == ([2,3,4] :: Deque Int)
  in t1 && t2 && t3 && t4 && t5 && t6 && t7 && t8

testConcatCpp :: Bool
testConcatCpp =
  let t1  = idcpp $ (concat ([[1,2],[3],[4,5]] :: List (List Int))) == ([1,2,3,4,5] :: List Int)
      t2  = idcpp $ (intercalate [0] [[1,2],[3,4],[5]]) == ([1,2,0,3,4,0,5] :: [Int])
      t3  = idcpp $ (([1,2] :: [Int]) <> [3,4]) == ([1,2,3,4] :: [Int])
      t4  = idcpp $ (([1,2] :: Deque Int) <> [3,4]) == ([1,2,3,4] :: Deque Int)
      t5  = idcpp $ ((mempty :: [Int])) == ([] :: [Int])
      t6  = idcpp $ ((mempty :: Deque Int)) == ([] :: Deque Int)
      t7  = idcpp $ (fold (+) 0 ([1,2,3,4] :: Deque Int)) == 10
      t8  = idcpp $ (map (\x -> x + 1) ([1,2,3] :: Deque Int)) == ([2,3,4] :: Deque Int)
  in t1 && t2 && t3 && t4 && t5 && t6 && t7 && t8

testConcatR :: Bool
testConcatR =
  let t1  = idpy $ (concat ([[1,2],[3],[4,5]] :: List (List Int))) == ([1,2,3,4,5] :: List Int)
      t2  = idpy $ (intercalate [0] [[1,2],[3,4],[5]]) == ([1,2,0,3,4,0,5] :: [Int])
      t3  = idpy $ (([1,2] :: [Int]) <> [3,4]) == ([1,2,3,4] :: [Int])
      t4  = idpy $ (([1,2] :: Deque Int) <> [3,4]) == ([1,2,3,4] :: Deque Int)
      t5  = idpy $ ((mempty :: [Int])) == ([] :: [Int])
      t6  = idpy $ ((mempty :: Deque Int)) == ([] :: Deque Int)
      t7  = idpy $ (fold (+) 0 ([1,2,3,4] :: Deque Int)) == 10
      t8  = idpy $ (map (\x -> x + 1) ([1,2,3] :: Deque Int)) == ([2,3,4] :: Deque Int)
  in t1 && t2 && t3 && t4 && t5 && t6 && t7 && t8
