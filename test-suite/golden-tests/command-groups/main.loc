module main (
  --* group: math
  --* Mathematical operations
  double, triple,

  --* group: text
  --* Text utilities
  greet,

  --* group:
  version
)

double :: Int -> (Int, Int)
double x = (x, x)

triple :: Int -> (Int, Int, Int)
triple x = (x, x, x)

greet :: Str -> [Str]
greet x = [x, x]

version :: Int
version = 42
