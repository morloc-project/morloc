-- Uniqueness (CAS-per-kind) and refusal guards on stdio.
--
--   * `twoStdin`, `twoStdout`, `twoStderr` -- second open of the same
--     stdio kind hits the SHM claim CAS and errors.
--   * `reopenAfterClose` -- @close releases the claim, so a subsequent
--     open of the same kind succeeds.
--   * `allThreeAtOnce` -- the three claim slots are independent.
--   * `openDevStdout`, `openDevStderr` -- `@open` on `/dev/stdout` /
--     `/dev/stderr` is refused (a naive user would otherwise race the
--     nexus's own fd 1/2); use `@stdout` / `@stderr` instead.
--   * `openDevStdin` -- `/dev/stdin` is a supported input, not a refused
--     path: `@open :: IStream` routes to the stdin channel. In a pure
--     (nexus-evaluated) command like this one -- no language pool to read
--     stdin -- it errors cleanly instead.

module main
  ( twoStdin
  , twoStdout
  , twoStderr
  , reopenAfterClose
  , allThreeAtOnce
  , openDevStdin
  , openDevStdout
  , openDevStderr
  )

import root-py

twoStdin :: <IO, Err> (IStream Int)
twoStdin = do
  @stdin :: <IO, Err> IStream Int
  @stdin :: <IO, Err> IStream Int

twoStdout :: <IO, Err> (OStream Int)
twoStdout = do
  @stdout :: <IO, Err> OStream Int
  @stdout :: <IO, Err> OStream Int

twoStderr :: <IO, Err> (OStream Int)
twoStderr = do
  @stderr :: <IO, Err> OStream Int
  @stderr :: <IO, Err> OStream Int

reopenAfterClose :: <IO, Err> ()
reopenAfterClose = do
  s1 <- @stdin :: <IO, Err> IStream Int
  @close s1
  s2 <- @stdin :: <IO, Err> IStream Int
  @close s2

allThreeAtOnce :: <IO, Err> ()
allThreeAtOnce = do
  i <- @stdin :: <IO, Err> IStream Int
  o <- @stdout :: <IO, Err> OStream Int
  e <- @stderr :: <IO, Err> OStream Int
  @close i
  @close o
  @close e

openDevStdin :: <IO, Err> (IStream Int)
openDevStdin = @open "/dev/stdin" :: <IO, Err> IStream Int

openDevStdout :: <IO, Err> (OStream Int)
openDevStdout = @open "/dev/stdout" :: <IO, Err> OStream Int

openDevStderr :: <IO, Err> (OStream Int)
openDevStderr = @open "/dev/stderr" :: <IO, Err> OStream Int
