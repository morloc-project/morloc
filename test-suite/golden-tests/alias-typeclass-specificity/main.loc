module main (test_result)

import root-py

type A = Str
type B = A

type A' = Str
type B' = A'

type C = Str
type D = C

class Foo a where
  dofoo :: a -> Str

instance Foo Str where
  dofoo x = "#{x} : Str"

instance Foo A where
  dofoo x = "#{x} : A"

instance Foo B where
  dofoo x = "#{x} : B"

instance Foo A' where
  dofoo x = "#{x} : prime"

instance Bar Str where
  dobar x = "#{x} : str bar"


class Bar a where
  dobar :: a -> Str

instance Bar A' where
  dobar x = "#{x} : A' bar"

test_result =
  dofoo ("a"  :: A ) == "a : A"   &&
  dofoo ("b"  :: B ) == "b : B"   &&
  dofoo ("a'" :: A') == "a' : prime" &&
  dofoo ("b'" :: A') == "b' : prime" && -- inherits from parent type A'
  dofoo ("c" ::  C ) == "c : Str" &&
  dofoo ("d" ::  D ) == "d : Str" &&
  dobar ("a"  :: A ) == "a : str bar"   &&
  dobar ("b"  :: B ) == "b : str bar"   &&
  dobar ("a'" :: A') == "a' : A' bar" &&
  dobar ("b'" :: A') == "b' : A' bar"
