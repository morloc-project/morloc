module main (pipeline)

import root
import table-py

source Py from "src.py" ("readData", "lookupRow")

-- A comprehensive demo pipeline exercising multiple typed Table operations
-- in series. Type-checking guarantees that:
--   - the column schema {id=Int, value=Real} is preserved through the
--     row-truncating slice, the rbind, and the lookupRow query;
--   - row-count Nat arithmetic composes correctly (rbind doubles the
--     slice's row count);
--   - cross-stage data flow is type-safe even though the result is
--     finally a Real (via lookupRow).
-- The pipeline:
--   readData n      ->  Table n {id=Int, value=Real}     -- input
--   sliceRows 0 5   ->  Table m {id=Int, value=Real}     -- truncate
--   rbind self      ->  Table (m+m) {id=Int, value=Real} -- duplicate
--   lookupRow 0     ->  Real                              -- query

readData :: Int -> Table n {id=Int, value=Real}
lookupRow :: Int -> Table n {id=Int, value=Real} -> Real

pipeline :: Int -> Int -> Real
pipeline n i =
  let raw     = readData n
      first5  = sliceRows 0 5 raw
      doubled = rbind first5 first5
  in lookupRow i doubled
