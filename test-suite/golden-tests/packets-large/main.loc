module main (cid, pid, rid)

source Cpp from "foo.h" ("cid")
source Py from "foo.py" ("pid")
source R from "foo.R" ("rid")

type Cpp => Str = "std::string"
type Py => Str = "str"
type R => Str = "character"

--' A large text read from a file
--' source:file
type Text = Str

cid :: Text -> Str

pid :: Text -> Str

rid :: Text -> Str
