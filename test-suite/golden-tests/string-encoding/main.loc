module main (foor, fooc, foop)

import root-py
import root-cpp
import root-r

source Py from "foo.py" ("mlc_foo" as pfoo)
source Cpp from "foo.hpp" ("mlc_foo" as cfoo)
source R from "foo.R" ("mlc_foo" as rfoo)

pfoo :: a -> a
cfoo :: a -> a
rfoo :: a -> a

foor :: (Int, Str) -> Str
foor = rfoo . rfoo . .1

fooc :: (Int, Str) -> Str
fooc = cfoo . cfoo . .1

foop :: (Int, Str) -> Str
foop = pfoo . pfoo . .1
