module main (small)

import tables-py

source Py from "src.py" ("makeT")

-- A Table with a fully-specified type-level schema. The Nat slot carries
-- the row count (left polymorphic here, solved at call site); the Rec
-- slot carries the column-name/type schema {x=Int, y=Str}.
makeT :: Int -> Table n {x=Int, y=Str}

-- head's polymorphism preserves the column schema across the row count
-- change. The Nat slot is independent (m can differ from n); the Rec
-- slot must match exactly.
small :: Int -> Int -> Table m {x=Int, y=Str}
small total take = head take (makeT total)
