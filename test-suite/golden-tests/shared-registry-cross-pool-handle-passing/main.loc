-- Handle passes A -> nexus -> B -> nexus -> A -> @close.
-- The int handle returned by pool A's @open is interpretable in
-- pool B because the slot lives in shared SHM. Pool B's @write
-- contributes to the same buffer/cursor; pool A's @close
-- finalises.
--
-- @flen reads element_count from the shared SHM diag, which IS
-- updated by every writer atomically. So the total includes
-- contributions from both pools regardless of which pool's
-- local subpacket_index ended up tracking them.

module main (testRoundTrip)

import root-py
import root-cpp

testRoundTrip :: Str -> <IO, Err> Int
testRoundTrip path = do
  o <- @open (idcpp path) :: <IO, Err> OStream Int
  @write 0 o (idpy [1,2,3])
  @write 0 o (idcpp [1,2,3])
  @write 0 o (idpy [4, 5])
  @write 0 o (idcpp [6,7,8])
  @close o
  s <- @open path :: <IO, Err> IStream Int
  @flen s
