-- Test the string type hierarchy from the types-hierarchies tutorial.
--
-- Hierarchy:
--   Str                 (root)
--   +-- Bytes           (concrete override: Py => "bytes")
--   +-- Filename        (transparent alias, no override)
--
-- Tests:
--   1. toBytes/fromBytes conversion between Str and Bytes
--   2. Filename as transparent alias (usable wherever Str is)
--   3. Filelike typeclass: Filename has it, Str does not
--   4. Stringlike typeclass: Str and Bytes each have instances
--   5. Filename inherits Stringlike from Str
--   6. Bytes specialization uses its own Stringlike, not Str's

module main (test_result)

import root-py

-- === Type hierarchy ===

-- new type with same wire format as string but different native representation
newtype Bytes = Str
type Py => Bytes = "bytes"

-- new type with same wire format and native representation as Str, but different typeclasses
newtype Filename = Str

-- === Conversion functions ===

instance Packable Str Bytes where
  source Py from "strlib.py" ("to_bytes" as pack)
  source Py from "strlib.py" ("from_bytes" as unpack)

-- === Typeclass: Filelike (Filename only) ===

class Filelike a where
  extension :: a -> Str

instance Filelike Filename where
  source Py from "strlib.py" ("get_extension" as extension)

-- === Typeclass: Stringlike (Str and Bytes) ===

class Stringlike a where
  split :: Str -> a -> [a]
  trim :: a -> a

instance Stringlike Str where
  source Py from "strlib.py" ("split_str" as split, "trim_str" as trim)

instance Stringlike Bytes where
  source Py from "strlib.py" ("split_bytes" as split, "trim_bytes" as trim)

instance Stringlike Filename where
  source Py from "strlib.py" ("split_str" as split, "trim_str" as trim)

-- === Tests ===

test_result =
  -- Conversion round-trip
  let s = "hello"
      b = pack s :: Bytes
      s2 = unpack b
  in s == s2

  -- 3. Filelike on Filename
  && extension ("archive.tar.gz" :: Filename) == ".gz"

  -- 4. Stringlike on Str
  && split "," "a,b,c" == ["a", "b", "c"]
  && trim "  hello  " == "hello"

  -- 4b. Stringlike on Bytes
  && split "," ("a,b,c" :: Bytes) == (["a", "b", "c"] :: [Bytes])
  && trim ("  hello  " :: Bytes) == ("hello" :: Bytes)

  -- 5. Filename inherits Stringlike from Str
  && split "/" ("src/main.py" :: Filename) == (["src", "main.py"] :: [Filename])
  && trim ("  path  " :: Filename) == ("path" :: Filename)

  -- 6. Stringlike on Bytes (uses its own instance, not Str's)
  && split "," ("x,y,z" :: Bytes) == (["x", "y", "z"] :: [Bytes])
  && trim ("  data  " :: Bytes) == ("data" :: Bytes)
