-- Test that Deque has Semigroup and Monoid instances and that list
-- literals can construct Deque values via the @Packable (List a)
-- (Deque a)@ instance declared in root. (Replaces the earlier
-- @Array@-based form; @Array@ has been removed in favor of @Vector@
-- and @Deque@.)

module main (testDequeMonoidPy, testDequeMonoidCpp, testDequeMonoidR)

import root-py
import root-cpp
import root-r

testDequeMonoidPy :: Bool
testDequeMonoidPy =
  let t1 = (([1,2] :: Deque Int) <> [3,4]) == [1,2,3,4]
      t2 = (mempty :: Deque Int) == []
      t3 = concat ([[1,2],[3],[4,5]] :: Deque (Deque Int)) == [1,2,3,4,5]
  in t1 && t2 && t3

testDequeMonoidCpp :: Bool
testDequeMonoidCpp =
  let t1 = (([1,2] :: Deque Int) <> [3,4]) == [1,2,3,4]
      t2 = (mempty :: Deque Int) == []
      t3 = concat ([[1,2],[3],[4,5]] :: Deque (Deque Int)) == [1,2,3,4,5]
  in t1 && t2 && t3

testDequeMonoidR :: Bool
testDequeMonoidR =
  let t1 = (([1,2] :: Deque Int) <> [3,4]) == [1,2,3,4]
      t2 = (mempty :: Deque Int) == []
      t3 = concat ([[1,2],[3],[4,5]] :: Deque (Deque Int)) == [1,2,3,4,5]
  in t1 && t2 && t3
