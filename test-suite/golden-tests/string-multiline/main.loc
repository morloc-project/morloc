module main (s1, s2, s3, s4, s5, s6, s7, s8)

s1 =
  """
    This is the start of a grand paragraph. That
  has many lines that have few initial spaces than
  the first paragraph.
  """

s2 = """you can also use "multiline" strings in one line with internal quotes"""

s3 = '''single quotes are also OK'''

-- empty string
s4 =
  """
  """

-- quote right before closing: """bar - "foo"""" has content bar - "foo"
s5 = """bar - "foo""""

-- seven quotes total: """ + " + """ -> content is "
s6 = """""""

-- single-quote variant: content is bar - 'foo'
s7 = '''bar - 'foo''''

-- seven single quotes: ''' + ' + ''' -> content is '
s8 = '''''''
