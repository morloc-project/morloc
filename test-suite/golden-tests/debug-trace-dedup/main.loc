module main (boomP2)

import root-py

source Py from "throw.py" ("pyThrowBoth")

pyThrowBoth :: Int -> Int -> Int

-- Two-arg function called with the SAME value for both args. Content-
-- addressed dedup must produce exactly one .pkt file (not two), and
-- the rendered trace must point both arg[0] and arg[1] at it.
boomP2 :: Int -> Int -> Int
boomP2 a b = idpy (pyThrowBoth a b)
