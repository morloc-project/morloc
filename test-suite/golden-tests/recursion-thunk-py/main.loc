-- Test exported recursive function returning an effect type.
-- sumDown n = 0 + 1 + 2 + ... + n (each term doubled by sourced fn)

module main (sumDown)

import root-py

source Py from "foo.py" ("double")

double :: Int -> <IO> Int

sumDown :: Int -> <IO> Int
sumDown n
  ? n <= 0 = double 0
  : do
      x <- double n
      rest <- sumDown (n - 1)
      x + rest
