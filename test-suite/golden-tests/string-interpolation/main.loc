module main (sr, spy, scpp, escR, escPy, escCpp, trpR, trpPy, trpCpp)

import root
import root-r
import root-py
import root-cpp

sr :: Str -> Str -> Str
sr x y = "x=#{idr x};y=#{idr y};"

spy :: Str -> Str -> Str
spy x y = "x=#{idpy x};y=#{idpy y};"

scpp :: Str -> Str -> Str
scpp x y = "x=#{idcpp x};y=#{idcpp y};"

-- test escape sequences inside interpolated strings
escR :: Str -> Str
escR x = "a\t\"#{idr x}\nb"

escPy :: Str -> Str
escPy x = "a\t\"\"\"#{idpy x}\nb"

escCpp :: Str -> Str
escCpp x = "a\t\"#{idcpp x}\nb"

-- triple-quoted strings must support #{...} interpolation just like
-- single-quoted ones (regression for C17). The result must match the
-- corresponding sr/spy/scpp output exactly.
trpR :: Str -> Str -> Str
trpR x y = """x=#{idr x};y=#{idr y};"""

trpPy :: Str -> Str -> Str
trpPy x y = """x=#{idpy x};y=#{idpy y};"""

trpCpp :: Str -> Str -> Str
trpCpp x y = """x=#{idcpp x};y=#{idcpp y};"""
