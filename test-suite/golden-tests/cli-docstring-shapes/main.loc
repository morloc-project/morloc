module main
  ( str_default
  , str_file
  , str_check_r
  , bytes_default
  , bytes_hybrid
  , bytes_only
  , bytes_inline
  , bytes_int32
  , bytes_float64
  , bytes_bool
  , list_str
  , list_int
  , list_tuple_json
  , list_tuple_tsv
  , list_path_check
  , many_str
  , many_int
  , default_tuple
  , record_list_str
  , record_list_int
  , record_dna_len
  , record_pathr_len
  )

import root-py

source Py from "helper.py"
  ( "py_id"
  , "py_size"
  , "py_sum_int"
  , "py_sum_float"
  , "py_fst_int"
  , "py_rec_xs_len"
  , "py_rec_ys_sum"
  , "py_rec_dna_len"
  , "py_rec_pathr_len"
  )

py_id        :: a -> a
py_size      :: [a] -> Int
py_sum_int   :: [Int] -> Int
py_sum_float :: [Float64] -> Float64
py_fst_int   :: (Int, Str) -> Int
py_rec_xs_len :: RecOpts -> Int
py_rec_ys_sum :: RecOpts -> Int
py_rec_dna_len :: RecOpts -> Int
py_rec_pathr_len :: RecOpts -> Int

--' Str default inline: echoes argv verbatim as the Str value.
str_default :: Str -> Str
str_default s = py_id s

--' Str source: file: returns the contents of the path argument.
str_file ::
  --' source: file
  Str -> Str
str_file s = py_id s

--' Str check.path: r: argv must be a readable path; returns the path.
str_check_r ::
  --' check.path: r
  Str -> Str
str_check_r s = py_id s

--' [UInt8] default JSON inline: returns the array length.
bytes_default :: [UInt8] -> Int
bytes_default xs = py_size xs

--' [UInt8] form: bytes: file is sniffed (packet -> raw); count bytes.
bytes_hybrid ::
  --' form: bytes
  [UInt8] -> Int
bytes_hybrid xs = py_size xs

--' [UInt8] form: bytes-only: file is raw bytes (no sniff); count.
bytes_only ::
  --' form: bytes-only
  [UInt8] -> Int
bytes_only xs = py_size xs

--' [UInt8] inline + form: bytes: ASCII chars become bytes; count.
bytes_inline ::
  --' source: inline
  --' form: bytes
  [UInt8] -> Int
bytes_inline xs = py_size xs

--' [Int32] form: bytes: file has packed 32-bit ints; count elements.
bytes_int32 ::
  --' form: bytes
  [Int32] -> Int
bytes_int32 xs = py_size xs

--' [Float64] form: bytes-only: file is packed 8-byte floats; sum.
bytes_float64 ::
  --' form: bytes-only
  [Float64] -> Float64
bytes_float64 xs = py_sum_float xs

--' [Bool] form: bytes: file is 0/1 bytes; count elements.
bytes_bool ::
  --' form: bytes
  [Bool] -> Int
bytes_bool xs = py_size xs

--' [Str] form: list: file has one Str per line; count lines.
list_str ::
  --' form: list
  [Str] -> Int
list_str xs = py_size xs

--' [Int] form: list: file has one Int per line; return the sum.
list_int ::
  --' form: list
  [Int] -> Int
list_int xs = py_sum_int xs

--' [(Int, Str)] form: list: JSON-array-per-line tuple; count rows.
list_tuple_json ::
  --' form: list
  [(Int, Str)] -> Int
list_tuple_json xs = py_size xs

--' [(Int, Str)] form: list: TSV/CSV tabular fallback; count rows.
list_tuple_tsv ::
  --' form: list
  [(Int, Str)] -> Int
list_tuple_tsv xs = py_size xs

--' [Str] form: list + list.check.path: r: each line readable; count.
list_path_check ::
  --' form: list
  --' list.check.path: r
  [Str] -> Int
list_path_check xs = py_size xs

--' [Str] many: true: variadic argv tokens; count tokens.
many_str ::
  --' many: true
  [Str] -> Int
many_str xs = py_size xs

--' [Int] many: true: variadic argv Int tokens; return the sum.
many_int ::
  --' many: true
  [Int] -> Int
many_int xs = py_sum_int xs

--' (Int, Str) default JSON: extract the first (Int) element of argv.
default_tuple :: (Int, Str) -> Int
default_tuple t = py_fst_int t

--' Options record whose per-field directives exercise the four
--' shape-family paths (`form: list`, `source: inline + form: bytes`,
--' `check.path:`, Unix `-` shorthand) across the unrolled-record
--' boundary.
--' unroll: true
record RecOpts where
  --' one Str per line, JSON array, or `-` for stdin
  --' arg: --xs
  --' form: list
  --' default: []
  xs :: [Str]

  --' one Int per line, JSON array, or `-` for stdin
  --' arg: --ys
  --' form: list
  --' default: []
  ys :: [Int]

  --' ASCII bytes shortcut on `[UInt8]`: `--dna GATTACA` becomes
  --' `[71,65,84,84,65,67,65]` before the value reaches the pool.
  --' arg: --dna
  --' source: inline
  --' form: bytes
  --' default: []
  dna :: [UInt8]

  --' `check.path: r` gate: `--pathr FILE` must be readable at CLI
  --' parse time; `-` rewrites to `/dev/stdin`.
  --' arg: --pathr
  --' check.path: r
  --' default: "/dev/null"
  pathr :: Str

record Py => RecOpts = "dict"

--' Return the number of Str elements in the unrolled record field
--' `--xs`. `form: list` on the record entry means `--xs FILE` reads
--' one Str per line from FILE.
record_list_str :: RecOpts -> Int
record_list_str opts = py_rec_xs_len opts

--' Return the sum of Int elements in the unrolled record field
--' `--ys`. `form: list` on the record entry means `--ys FILE` reads
--' one Int per line from FILE.
record_list_int :: RecOpts -> Int
record_list_int opts = py_rec_ys_sum opts

--' Return the byte count of the `--dna` field. Exercises the
--' `source: inline + form: bytes` ASCII shortcut on a record entry.
record_dna_len :: RecOpts -> Int
record_dna_len opts = py_rec_dna_len opts

--' Return the string length of the `--pathr` field (after `-` ->
--' `/dev/stdin` substitution and `check.path: r` validation).
record_pathr_len :: RecOpts -> Int
record_pathr_len opts = py_rec_pathr_len opts
