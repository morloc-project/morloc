module main
  ( showInt
  , showReal
  , showBool
  , showStr
  , showList
  , showTuple
  , showRecord
  , showNested
  , showOptSome
  , showOptNone
  , showEmptyList
  , readInt
  , readReal
  , readBool
  , readStr
  , readList
  , readTuple
  , readRecord
  , readInvalid
  , readTypeMismatch
  , readEmptyStr
  , roundTripInt
  , roundTripReal
  , roundTripBool
  , roundTripStr
  , roundTripList
  , roundTripTuple
  , roundTripRecord
  , roundTripNested
  , showShowInt
  )

-- No language-specific imports: all nexus-level evaluation
--
-- @read moved to `<Err> a` in the effect-migration; parse failure
-- raises Err instead of returning None. Every @read caller either
-- @catches (with a sentinel) or declares <Err> in its signature.

effect Err

record Point where
  x :: Int
  y :: Int

-- === @show tests ===

showInt :: Str
showInt = @show 42

showReal :: Str
showReal = @show 3.14

showBool :: Str
showBool = @show True

showStr :: Str
showStr = @show "hello"

showList :: Str
showList = @show [1, 2, 3]

showTuple :: Str
showTuple = @show (10, "abc")

showRecord :: Str
showRecord = @show {x = 1, y = 2}

showNested :: Str
showNested = @show [[1, 2], [3, 4]]

-- @read is now `<Err> a`; wrap in @catch to recover a value to @show.
showOptSome :: Str
showOptSome = @show (@catch (@read "42") -1)

showOptNone :: Str
showOptNone = @show (@catch (@read "bad") -1)

showEmptyList :: Str
showEmptyList = @show ([] :: [Int])

-- === @read tests -- each returns bare `a`; sentinel on Err ===

readInt :: Int
readInt = @catch (@read "42") -1

readReal :: Real
readReal = @catch (@read "3.14") -1.0

readBool :: Bool
readBool = @catch (@read "true") False

readStr :: Str
readStr = @catch (@read "\"hello\"") "err"

readList :: [Int]
readList = @catch (@read "[1,2,3]") []

readTuple :: (Int, Str)
readTuple = @catch (@read "[10,\"abc\"]") (0, "err")

readRecord :: Point
readRecord = @catch (@read "{\"x\":1,\"y\":2}") {x = 0, y = 0}

readInvalid :: Int
readInvalid = @catch (@read "not_a_number") -1

readTypeMismatch :: Int
readTypeMismatch = @catch (@read "\"hello\"") -1

readEmptyStr :: Int
readEmptyStr = @catch (@read "") -1

-- === round-trip tests: same shape via @catch ===

roundTripInt :: Int
roundTripInt = @catch (@read (@show 42)) -1

roundTripReal :: Real
roundTripReal = @catch (@read (@show 3.14)) -1.0

roundTripBool :: Bool
roundTripBool = @catch (@read (@show True)) False

roundTripStr :: Str
roundTripStr = @catch (@read (@show "hello")) "err"

roundTripList :: [Int]
roundTripList = @catch (@read (@show [1, 2, 3])) []

roundTripTuple :: (Int, Str)
roundTripTuple = @catch (@read (@show (10, "abc"))) (0, "err")

roundTripRecord :: Point
roundTripRecord = @catch (@read (@show {x = 1, y = 2})) {x = 0, y = 0}

roundTripNested :: [[Int]]
roundTripNested = @catch (@read (@show [[1, 2], [3, 4]])) []

-- === edge case: @show of @show ===

showShowInt :: Str
showShowInt = @show (@show 42)
