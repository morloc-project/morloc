module main (test)

test = (testInts, testBigInts, testHugeInts, testFloats)

testInts = [-42, 42, 0x2a, 0X2a, 0o755, 0O755, 0b0001, 0B0001, -0x2a, -0X2a, -0o755, -0O755, -0b0001, -0B0001]

testBigInts = [0xDEADBEEF, 4294967295, 9223372036854775807, -9223372036854775808]

-- integers that exceed 64 bits
testHugeInts =
  [ 18446744073709551616          -- 2^64: just over uint64 max
  , -9223372036854775809           -- just under int64 min
  , 100000000000000000000000000000 -- 10^29: a 97-bit number
  , -100000000000000000000000000000
  ]

testFloats = [4.2, 4.2E5, 4.2e-2]
