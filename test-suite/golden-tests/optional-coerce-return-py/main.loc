module main
  ( testReturn
  , optOfPure
  )

type Py => Int = "int"

-- Return-position coercion: function body has type Int, declared return is ?Int.
pCoerce :: Int -> ?Int
pCoerce x = x

testReturn :: ?Int
testReturn = pCoerce 7

-- Top-level pure binding: declared ?Int, RHS is a bare Int literal.
optOfPure :: ?Int
optOfPure = 42
