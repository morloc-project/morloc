-- Test non-exported recursive helper returning a thunk type.
-- Combines the helper extraction fix (Realize.hs) with the
-- ThunkT stripping fix (Express.hs). This is the pattern from
-- the ecosystem example where simulateR was a non-exported
-- recursive helper returning {[[Cell]]}.
-- sumDown n = 0 + 1 + 2 + ... + n (each term doubled by sourced fn)

module main (sumDown)

import root-cpp

source Cpp from "foo.hpp" ("double_val")

type Cpp => Int = "int"

double_val :: Int -> {Int}

-- Exported wrapper delegates to non-exported recursive helper
sumDown :: Int -> {Int}
sumDown n = helper n

-- Non-exported recursive helper returning {Int}
helper :: Int -> {Int}
helper n
  ? n <= 0 = double_val 0
  : do
      x <- double_val n
      rest <- helper (n - 1)
      {x + rest}
