module main (bound, double, both)

import tables-py

-- Stage 4 Table operations exercised at the type level. These signatures
-- demonstrate that:
--   * row counts compose via Nat arithmetic (rbind: n1 + n2)
--   * column schemas compose via Rec union (cbind: r1 + r2)
--   * polymorphic row vars are solved per call site
--   * the solver normalises Nat/Rec arithmetic so the inferred type
--     reads cleanly

-- Two ground tables with the same column schema and same row count.
mkLeft :: Table 5 {x=Int}
mkRight :: Table 7 {x=Int}

-- rbind sums row counts; the column schema is preserved.
bound :: Table 12 {x=Int}
bound = rbind mkLeft mkRight

-- A polymorphic identity to verify row variables survive a call.
mk10 :: Table 10 {x=Int}

double :: Table 20 {x=Int}
double = rbind mk10 mk10

-- cbind unions schemas; row counts must match.
mkY :: Table 5 {y=Str}

both :: Table 5 ({x=Int} + {y=Str})
both = cbind mkLeft mkY
