-- Regression test for a latent bug in the SerialAST builder.
--
-- @newtype Deque a = List a@ in the stdlib (with a per-language form
-- @std::deque<$1>@ on the C++ side and a @Packable (List a) (Deque a)@
-- instance) combines with specialized integer aliases (e.g. @type
-- I32 = Int@). A previous bug fully evaluated the type when looking
-- up the outer alias, collapsing the element type from @I32@ to
-- @Int@ and emitting BigInt schema (16-byte width) instead of @i4@
-- (4-byte width). The mismatch surfaced only cross-language with
-- specialized element types -- the older tests used the now-removed
-- @Array@ type with only @Int@/@Real@/@Bool@, all of which are
-- terminal serialization base types.
--
-- This test forces the previously-latent code path: a parameterized
-- newtype-of-list (@Deque@) with element types that themselves alias
-- (@I32 -> Int@, @F32 -> Real@, etc.), passed across language
-- boundaries.
module main
  ( testDequeI32Cp
  , testDequeI32Pc
  , testDequeI64Cp
  , testDequeI64Pc
  , testDequeF32Cp
  , testDequeF32Pc
  , testDequeF64Cp
  , testDequeF64Pc
  )

import root-cpp
import root-py

source Cpp from "src.hpp"
  ( "cppMakeI32" , "cppSumI32"
  , "cppMakeI64" , "cppSumI64"
  , "cppMakeF32" , "cppSumF32"
  , "cppMakeF64" , "cppSumF64"
  )

source Py from "src.py"
  ( "pyMakeI32" , "pySumI32"
  , "pyMakeI64" , "pySumI64"
  , "pyMakeF32" , "pySumF32"
  , "pyMakeF64" , "pySumF64"
  )

cppMakeI32 :: Deque I32
cppSumI32  :: Deque I32 -> Int
pyMakeI32  :: Deque I32
pySumI32   :: Deque I32 -> Int

cppMakeI64 :: Deque I64
cppSumI64  :: Deque I64 -> Int
pyMakeI64  :: Deque I64
pySumI64   :: Deque I64 -> Int

cppMakeF32 :: Deque F32
cppSumF32  :: Deque F32 -> Real
pyMakeF32  :: Deque F32
pySumF32   :: Deque F32 -> Real

cppMakeF64 :: Deque F64
cppSumF64  :: Deque F64 -> Real
pyMakeF64  :: Deque F64
pySumF64   :: Deque F64 -> Real

-- Cross-language pairs: writer + reader must agree on element width.
-- Sum of [10..17] = 108 (I32, I64).
-- Sum of [1.5, 2.5, 3.5] = 7.5 (F32, F64).

testDequeI32Cp :: Int
testDequeI32Cp = pySumI32 cppMakeI32
testDequeI32Pc :: Int
testDequeI32Pc = cppSumI32 pyMakeI32

testDequeI64Cp :: Int
testDequeI64Cp = pySumI64 cppMakeI64
testDequeI64Pc :: Int
testDequeI64Pc = cppSumI64 pyMakeI64

testDequeF32Cp :: Real
testDequeF32Cp = pySumF32 cppMakeF32
testDequeF32Pc :: Real
testDequeF32Pc = cppSumF32 pyMakeF32

testDequeF64Cp :: Real
testDequeF64Cp = pySumF64 cppMakeF64
testDequeF64Pc :: Real
testDequeF64Pc = cppSumF64 pyMakeF64
