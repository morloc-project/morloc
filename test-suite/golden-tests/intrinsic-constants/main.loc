module main (langstr)

import root-py (idpy)
import root-cpp (idcpp)
import root-r (idr)

-- @load raises Err on missing file; @catch substitutes an empty list.
-- The three round-tripped loads all succeed; the "zany" load is missing
-- and falls through to the empty-list fallback.
langstr :: <IO, Err> ([Str],[Str],[Str],[Str])
langstr = do
  @save  0 (idpy ["hi", @lang]) "z"
  @savem "zp" (idpy ["hi", @lang])
  @savej "zj" (idpy ["hi", @lang])
  xs  <- @load "z"
  ys  <- @load "zp"
  zs  <- @load "zj"
  bad <- @catch (@load "zany") []
  (xs, ys, zs, bad)
