module main (langstr)

import root-py (idpy)
import root-cpp (idcpp)
import root-r (idr)

langstr :: <IO> (?[Str],?[Str],?[Str],?[Str])
langstr = do
  @save  0 (idpy ["hi", @lang]) "z"
  @savem "zp" (idpy ["hi", @lang])
  @savej "zj" (idpy ["hi", @lang])
  xs  <- @load "z"
  ys  <- @load "zp"
  zs  <- @load "zj"
  bad <- @load "zany"
  (xs, ys, zs, bad)
