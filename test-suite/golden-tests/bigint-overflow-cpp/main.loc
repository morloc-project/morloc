-- Test that passing a big integer from Python to C++ produces a clear error.
-- fact(100) is a 525-bit integer that cannot fit in any C++ primitive.
module main (factCpp)

import root-py
import root-cpp

fact :: Int -> Int
fact n
  ? n == 0 = 1
  : n * fact (n - 1)

factPy :: Int -> Int
factPy n = idpy (fact n)

factCpp :: Int -> Int
factCpp x = idcpp (factPy x)
