-- Test cross-language effect evaluation inside guard branches.

module main (guardCross)

import root-cpp
import root-py

source Py from "foo.py" ("py_double")
source Cpp from "foo.hpp" ("add")

type Cpp => Int = "int"
type Py => Int = "int"

py_double :: Int -> <IO> Int
add :: Int -> Int -> Int

guardCross :: Int -> <IO> Int
guardCross x
  ? x > 0 = do
      y <- py_double x
      add y 1
  : do
      0
