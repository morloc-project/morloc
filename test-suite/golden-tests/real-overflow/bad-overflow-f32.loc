-- Float literal that fits F64 but overflows F32 (max ~3.4e38).
-- The bound check is per-target-type: 1e100 is a finite Scientific that
-- becomes +Inf when converted to Float, so checkRealBounds catches it
-- against the F32-specific bound. Required generalTypeToSerialAST to
-- dispatch f32/f64 to SerialF32/SerialF64 (previously both
-- collapsed to SerialReal and only the F64 path was checked).
module badF32 (tooBigF32)

tooBigF32 :: F32
tooBigF32 = 1e100
