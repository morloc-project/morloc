pySumF32   :: Vector 4 F32 -> Real

cppMakeF64 :: Vector 4 F64
cppSumF64  :: Vector 4 F64 -> Real
pyMakeF64  :: Vector 4 F64
pySumF64   :: Vector 4 F64 -> Real

cppMakeI8Min :: Vector 1 I8
cppSumI8Min  :: Vector 1 I8 -> Int
pyMakeI8Min  :: Vector 1 I8
pySumI8Min   :: Vector 1 I8 -> Int

cppMakeU8Max :: Vector 1 U8
cppSumU8Max  :: Vector 1 U8 -> Int
