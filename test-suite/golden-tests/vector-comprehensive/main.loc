-- vector-comprehensive: full-cycle and zero-copy tests for 1D Vectors.
--
-- This test is designed to expose bugs. Each block targets a class of
-- failure mode that existing tests do not cover.
--
--   (1) Element-type coverage. Many widths (I8..I64, U8..U64,
--       F32) have never been round-tripped cross-language. Each
--       width carries its own NPY_TYPE, std::vector<T>, and R typedef
--       branch; any of them can silently fall back to a wrong dtype,
--       lose sign, or be widened to a different on-wire packing.
--
--   (2) Element-position correctness. Sum-based assertions pass even
--       if elements are shuffled. Powers-of-two probes (each position
--       contributes a unique bit) reveal shuffles that sums hide.
--
--   (3) File IO cycle via @save / @load. The intrinsic-load tests only
--       cover scalars and tuples. Vector with a Nat parameter has never
--       been pushed through @save and back.
--
--   (4) Zero-copy semantics. Below the 64 KB inline threshold a Python
--       consumer should see OWNDATA=True (memcpy from libc buffer);
--       above it should see OWNDATA=False (numpy view over SHM). No
--       existing test asserts on flags directly.
--
--   (5) Morloc-level ops on Vector. `type Vector n a = List a`, so
--       `sum`, `length`, `reverse`, `sort`, `map` should work via the
--       List instances; if alias-chain promotion breaks, this exposes
--       which ops actually flow through.
--
--   (6) Edge cases that have historically broken: empty (size 0),
--       single (size 1), and signed/unsigned extremes (-128 / 255).

module main
  ( cpRound, pcRound, prRound, rpRound, crRound, rcRound
  , cpI8, pcI8, cpI16, pcI16, cpI32, pcI32, cpI64, pcI64
  , cpU8, pcU8, cpU16, pcU16, cpU32, pcU32, cpU64, pcU64
  , cpF32, pcF32, cpF64, pcF64
  , cpI8Min, pcI8Min
  , cpU8Max, pcU8Max
  , cpPerm, pcPerm, prPerm, rpPerm, crPerm, rcPerm
  , fileBin, fileJson, fileMsg
  , fileSumBin, fileSumJson
  , zcShmPyPy, zcInlinePyPy
  , zcShmCpToPy, zcInlineCpToPy
  , zcShmRToPy
  , mlSum, mlLength, mlMap
  , emptyCross, singleCross
  , underThr, overThr
    -- (9) Literal inputs: morloc source literals + CLI literals
  , litSrcRealAnnot, litSrcRealInfer, litSrcIntAnnot
  , litCliReal, litCliInt
  , litCliRealCpp, litCliIntCpp
  , litCliRealR
  , litCliEmpty, litCliSingle
  )

import root-cpp
import root-py
import root-r (Real, Int, Bool)
import vector-cpp
import vector-py
import vector-r
import maybe
import maybe-cpp
import maybe-py
import maybe-r

