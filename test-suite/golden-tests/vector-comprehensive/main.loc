-- =========================================================================
-- Type signatures
-- =========================================================================

cppMakeReal10 :: Vector 10 Real
cppSumReal10  :: Vector 10 Real -> Real
pyMakeReal10  :: Vector 10 Real
pySumReal10   :: Vector 10 Real -> Real
rMakeReal10   :: Vector 10 Real
rSumReal10    :: Vector 10 Real -> Real

cppMakeI8  :: Vector 4 I8
cppSumI8   :: Vector 4 I8 -> Int
pyMakeI8   :: Vector 4 I8
pySumI8    :: Vector 4 I8 -> Int

cppMakeI16 :: Vector 4 I16
cppSumI16  :: Vector 4 I16 -> Int
pyMakeI16  :: Vector 4 I16
pySumI16   :: Vector 4 I16 -> Int

cppMakeI32 :: Vector 4 I32
cppSumI32  :: Vector 4 I32 -> Int
pyMakeI32  :: Vector 4 I32
pySumI32   :: Vector 4 I32 -> Int

cppMakeI64 :: Vector 4 I64
cppSumI64  :: Vector 4 I64 -> Int
pyMakeI64  :: Vector 4 I64
pySumI64   :: Vector 4 I64 -> Int

cppMakeU8  :: Vector 4 U8
cppSumU8   :: Vector 4 U8 -> Int
