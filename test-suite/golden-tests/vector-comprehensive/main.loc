pySumU8    :: Vector 4 U8 -> Int

cppMakeU16 :: Vector 4 U16
cppSumU16  :: Vector 4 U16 -> Int
pyMakeU16  :: Vector 4 U16
pySumU16   :: Vector 4 U16 -> Int

cppMakeU32 :: Vector 4 U32
cppSumU32  :: Vector 4 U32 -> U64
pyMakeU32  :: Vector 4 U32
pySumU32   :: Vector 4 U32 -> U64

cppMakeU64 :: Vector 4 U64
cppSumU64  :: Vector 4 U64 -> U64
pyMakeU64  :: Vector 4 U64
pySumU64   :: Vector 4 U64 -> U64

cppMakeF32 :: Vector 4 F32
cppSumF32  :: Vector 4 F32 -> Real
