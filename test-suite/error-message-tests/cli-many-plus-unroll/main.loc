-- `many: true` (collect N tokens into one list) and `unroll: true`
-- (explode a record into per-field flags) are mutually exclusive --
-- they describe incompatible CLI shapes for the same argument slot.
module main (f)

record Config where
  alpha :: Int
  beta :: Int

f ::
  --' many: true
  --' unroll: true
  Config ->
  Int
f c = 0
